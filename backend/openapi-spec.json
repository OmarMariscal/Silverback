{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "description": "Obtener el JWT para las cookies del dispositivo",
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthLoginRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Inicio de Sesión Exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthLoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciales Inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpErrorDto"
                }
              }
            }
          }
        },
        "summary": "Iniciar Sesión",
        "tags": [
          "Autenticación"
        ]
      }
    },
    "/api/v1/actividades/{act}-uuid/ficha-tecnica": {
      "get": {
        "description": "Obtener los detalles técnicos de una actividad principal",
        "operationId": "ActividadesController_getFichaTecnica",
        "parameters": [
          {
            "name": "act-uuid",
            "required": true,
            "in": "path",
            "description": "El identificador único (UUID) de la actividad principal",
            "schema": {
              "format": "uuid",
              "example": "act-01-uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ficha técnica recuperada con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FichaTecnicaResponse"
                }
              }
            }
          },
          "404": {
            "description": "UUID no identificado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpErrorDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Detalles técnicos",
        "tags": [
          "Actividades"
        ]
      }
    },
    "/api/v1/actividades/{actividadId}/sub-actividades/bulk": {
      "post": {
        "description": "Sincronización de las subactividades seleccionadas",
        "operationId": "ActividadesController_postSubActividadesBulk",
        "parameters": [
          {
            "name": "actividadId",
            "required": true,
            "in": "path",
            "description": "El identificador único (UUID) de la actividad a la que van dirigidas las sub-actividades",
            "schema": {
              "format": "uuid",
              "example": "act-01-uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Actividades agregadas exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubActividadesBulkResponse"
                }
              }
            }
          },
          "403": {
            "description": "Rol no autorizado para esta operación",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpErrorDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Selección de subactividades",
        "tags": [
          "Actividades"
        ]
      }
    }
  },
  "info": {
    "title": "API Silverback <3",
    "description": "Especificación técnica de los endpoints para auditoría, gestión documental y reportes.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "AuthLoginRequest": {
        "type": "object",
        "properties": {
          "correo": {
            "type": "string",
            "example": "monkeycodeinc@gmail.com",
            "description": "Correo electrónico previamente registrado"
          },
          "password": {
            "type": "string",
            "example": "Admin123!",
            "description": "Contraseña de acceso"
          }
        },
        "required": [
          "correo",
          "password"
        ]
      },
      "AuthLoginUserData": {
        "type": "object",
        "properties": {
          "rol": {
            "type": "string",
            "example": "CONTRALOR",
            "description": "Rol del usuario loggeado"
          },
          "centro_id": {
            "type": "string",
            "example": "uuid-cucei",
            "description": "UID del centro universitario"
          }
        },
        "required": [
          "rol",
          "centro_id"
        ]
      },
      "AuthLoginResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVC...",
            "description": "JWT para el envío en los headders"
          },
          "usuario": {
            "description": "Información básica del usuario autenticado.",
            "allOf": [
              {
                "$ref": "#/components/schemas/AuthLoginUserData"
              }
            ]
          }
        },
        "required": [
          "access_token",
          "usuario"
        ]
      },
      "HttpErrorDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "description": "Código de estado HTTP",
            "example": 401
          },
          "message": {
            "type": "object",
            "description": "Mensaje descriptivo del error",
            "example": "Credenciales inválidas"
          },
          "error": {
            "type": "string",
            "description": "Tipo de error HTTP",
            "example": "Unauthorized"
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "FichaTecnicaResponse": {
        "type": "object",
        "properties": {
          "justificacion": {
            "type": "string",
            "example": "Concluir y cerrar la revisión de la auditoría no. 055/2025...",
            "description": "Justificación técnica de la actividad principal"
          },
          "objetivo_general": {
            "type": "string",
            "example": "Verificar el adecuado cumplimiento en la integración...",
            "description": "Objetivo general de la actividad principal"
          },
          "objetivos_particulares": {
            "type": "string",
            "example": "Conclusión de la verificación de los procesos",
            "description": "Objetivos particulares de la actividad principal"
          }
        },
        "required": [
          "justificacion",
          "objetivo_general",
          "objetivos_particulares"
        ]
      },
      "SubActividadesResumen": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "sub-op-uuid-1",
            "description": "Identificador único (UUID) de la subactividad registrada"
          },
          "numero_orden": {
            "type": "string",
            "example": "1.1",
            "description": "Número de orden individual de la subactividad"
          },
          "semanas_totales": {
            "type": "number",
            "example": 8,
            "description": "Cálculo de las semanas totales que toma la subactividad"
          }
        },
        "required": [
          "id",
          "numero_orden",
          "semanas_totales"
        ]
      },
      "SubActividadesBulkResponse": {
        "type": "object",
        "properties": {
          "mensaje": {
            "type": "string",
            "example": "Se agregaron 2 sub-actividades exitosamente",
            "description": "Información relevante al resultado del proceso de bulk"
          },
          "data": {
            "description": "Array con el resumen de las sub-actividades agregadas",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SubActividadesResumen"
            }
          }
        },
        "required": [
          "mensaje",
          "data"
        ]
      }
    }
  }
}